#!/bin/bash
set -Eeuo pipefail
PROFILE_DIR="${NEXUS_BROWSER_PROFILE:-$HOME/.nexus/browser-profile}"
mkdir -p "$PROFILE_DIR"

if command -v chromium >/dev/null 2>&1; then
  ENGINE="chromium"
elif command -v chromium-browser >/dev/null 2>&1; then
  ENGINE="chromium-browser"
elif command -v brave-browser >/dev/null 2>&1; then
  ENGINE="brave-browser"
else
  echo "Nexus Browser precisa de chromium/brave-browser instalado."
  echo "Instale chromium ou inclua o pacote na ISO."
  exit 1
fi

exec "$ENGINE"   --user-data-dir="$PROFILE_DIR"   --no-first-run   --disable-sync   --disable-background-networking   --disable-component-update   --disable-domain-reliability   --disable-client-side-phishing-detection   --disable-features=InterestFeedContentSuggestions,PrivacySandboxSettings4,TopicsAPI,Fledge,AdInterestGroupAPI,SharedStorageAPI,AttributionReporting,OptimizationHints,MediaRouter,AutofillServerCommunication   --enable-features=HttpsUpgrades   --password-store=basic   --force-dark-mode   --fingerprinting-canvas-image-data-noise   --fingerprinting-canvas-measuretext-noise   --fingerprinting-client-rects-noise   "$@"
